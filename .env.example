# Supabase project URL (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (NEVER expose this in the browser — server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret invite code required to register
INVITE_CODE=your-secret-invite-code
